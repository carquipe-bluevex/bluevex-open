---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import Card from '../components/ui/Card.astro';
import Divider from '../components/ui/Divider.astro';
import Modal from '../components/ui/Modal.astro';
import Section from '../components/layout/Section.astro';
import Logo from '../components/shared/Logo.astro';
import Icon from '../components/shared/Icon.astro';
import EmailCta from '../components/ui/EmailCta.astro';
import ServiceFeatureCard from '../components/ui/ServiceFeatureCard.astro';
import Timeline from '../components/ui/Timeline.astro';
---

<BaseLayout
  title="Design System | BlueVex"
  description="BlueVex component library and design tokens reference."
  noIndex={true}
>

  <!-- ========================================================
       HERO
  ========================================================= -->
  <section class="ds-hero">
    <div class="container">
      <p class="overline">Sistema de diseño</p>
      <h1>BlueVex Design System</h1>
      <p class="body-l" style="color: var(--color-gray-600); max-width: 560px; margin-top: var(--space-4);">
        Tokens, componentes y patrones que garantizan consistencia visual en toda la web.
        Basado en el Brand Manual v1 (2026).
      </p>
    </div>
  </section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       COLORS
  ========================================================= -->
  <Section id="colors" overline="Identidad visual" heading="Paleta de colores" bg="white">
    <div class="ds-section-label">Colores de marca</div>
    <div class="ds-swatches">
      <div class="swatch" style="background:#16264C">
        <span class="swatch__label">Navy</span>
        <span class="swatch__hex">#16264C</span>
      </div>
      <div class="swatch swatch--light" style="background:#2FA4D9">
        <span class="swatch__label">Cyan</span>
        <span class="swatch__hex">#2FA4D9</span>
      </div>
    </div>

    <div class="ds-section-label mt-8">Neutros</div>
    <div class="ds-swatches">
      {[
        { name: 'White',      hex: '#FFFFFF', border: true },
        { name: 'Off-White',  hex: '#F7F9FF', border: true },
        { name: 'Gray 100',   hex: '#E9EFFF' },
        { name: 'Gray 400',   hex: '#A8AABC' },
        { name: 'Gray 600',   hex: '#747687' },
        { name: 'Gray 800',   hex: '#444655' },
      ].map(s => (
        <div class={`swatch ${s.hex === '#FFFFFF' || s.hex === '#F7F9FF' ? 'swatch--light' : ''}`}
          style={`background:${s.hex}; ${s.border ? 'border:1px solid #E9EFFF;' : ''}`}>
          <span class="swatch__label">{s.name}</span>
          <span class="swatch__hex">{s.hex}</span>
        </div>
      ))}
    </div>

    <div class="ds-section-label mt-8">Semánticos</div>
    <div class="ds-swatches">
      <div class="swatch" style="background:#1D9E75"><span class="swatch__label">Success</span><span class="swatch__hex">#1D9E75</span></div>
      <div class="swatch" style="background:#D2A517"><span class="swatch__label">Warning</span><span class="swatch__hex">#D2A517</span></div>
      <div class="swatch" style="background:#C0394B"><span class="swatch__label">Error</span><span class="swatch__hex">#C0394B</span></div>
      <div class="swatch swatch--light" style="background:#2FA4D9"><span class="swatch__label">Info</span><span class="swatch__hex">#2FA4D9</span></div>
    </div>
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       TYPOGRAPHY
  ========================================================= -->
  <Section id="typography" overline="Tipografía" heading="Sistema tipográfico" bg="off-white">
    <div class="ds-type-row">
      <span class="ds-type-label caption">Display XL · HK Grotesk 600 · 56px</span>
      <p class="display-xl">Tecnología que marca el rumbo.</p>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">Display · HK Grotesk 600 · 44px</span>
      <p class="display">Continuidad. Fiabilidad. Evolución.</p>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">H1 · HK Grotesk 600 · 32px</span>
      <h1>Soporte Tecnológico</h1>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">H2 · HK Grotesk 500 · 24px</span>
      <h2>Responsabilidad integral</h2>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">H3 · HK Grotesk 500 · 20px</span>
      <h3>Decisiones con criterio</h3>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">H4 · Inter 600 · 16px</span>
      <h4>Incidencias críticas: respuesta en menos de 2h</h4>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">Body L · Inter 400 · 18px</span>
      <p class="body-l">Nos encargamos de que tus sistemas funcionen sin interrupciones. Si hay un problema, lo resolvemos antes de que te afecte.</p>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">Body · Inter 400 · 16px</span>
      <p>Tu negocio funciona sin sobresaltos. Operación tecnológica estable y sin interrupciones, con responsabilidad clara y unificada.</p>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">Overline · Inter 500 · 11px UPPERCASE</span>
      <p class="overline">Servicios de continuidad</p>
    </div>
    <div class="ds-type-row">
      <span class="ds-type-label caption">Caption · Inter 400 · 12px</span>
      <p class="caption">Última actualización: marzo 2026 · BlueVex Technologies S.L.</p>
    </div>
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       BUTTONS
  ========================================================= -->
  <Section id="buttons" overline="Componentes" heading="Botones" bg="white">
    <div class="ds-row">
      <Button variant="primary">Primary</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="ghost">Ghost</Button>
      <Button variant="danger">Danger</Button>
    </div>

    <div class="ds-section-label mt-8">Tamaños</div>
    <div class="ds-row">
      <Button variant="primary" size="sm">Small</Button>
      <Button variant="primary" size="md">Medium</Button>
      <Button variant="primary" size="lg">Large</Button>
    </div>

    <div class="ds-section-label mt-8">Disabled</div>
    <div class="ds-row">
      <Button variant="primary" disabled>Disabled Primary</Button>
      <Button variant="secondary" disabled>Disabled Secondary</Button>
    </div>

    <div class="ds-section-label mt-8">Con enlace</div>
    <div class="ds-row">
      <EmailCta size="md" />
      <Button href="/servicios" variant="secondary">Ver servicios</Button>
    </div>
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       FORMS
  ========================================================= -->
  <Section id="forms" overline="Componentes" heading="Formularios" bg="off-white">
    <div class="ds-form">
      <div class="ds-form-row">
        <div class="ds-form-field">
          <label class="ds-form-label" for="ds-nombre">Nombre *</label>
          <input class="ds-form-input" type="text" id="ds-nombre" name="ds-nombre" placeholder="Tu nombre" />
        </div>
        <div class="ds-form-field">
          <label class="ds-form-label" for="ds-email">Email *</label>
          <input class="ds-form-input" type="email" id="ds-email" name="ds-email" placeholder="tu@empresa.com" />
        </div>
      </div>

      <div class="ds-form-field">
        <label class="ds-form-label" for="ds-empresa">Empresa</label>
        <input class="ds-form-input" type="text" id="ds-empresa" name="ds-empresa" placeholder="Nombre de la empresa" />
      </div>

      <div class="ds-form-row">
        <div class="ds-form-field">
          <label class="ds-form-label" for="ds-tamano">Tamaño de la compañía</label>
          <select class="ds-form-input ds-form-select" id="ds-tamano" name="ds-tamano">
            <option value="">Selecciona una opción</option>
            <option value="1-10">1 - 10 empleados</option>
            <option value="11-50">11 - 50 empleados</option>
            <option value="51-200">51 - 200 empleados</option>
            <option value="201-1000">201 - 1000 empleados</option>
          </select>
        </div>
        <div class="ds-form-field">
          <label class="ds-form-label" for="ds-telefono">Teléfono</label>
          <input class="ds-form-input" type="tel" id="ds-telefono" name="ds-telefono" placeholder="+34 600 000 000" />
        </div>
      </div>

      <div class="ds-form-field">
        <label class="ds-form-label" for="ds-cv">CV (PDF)</label>
        <input class="ds-form-input" type="file" id="ds-cv" name="ds-cv" accept="application/pdf" />
      </div>

      <div class="ds-form-field">
        <label class="ds-form-label" for="ds-mensaje">Cuéntanos más</label>
        <textarea class="ds-form-input ds-form-textarea" id="ds-mensaje" name="ds-mensaje" rows="4" placeholder="Describe brevemente tu situación."></textarea>
      </div>

      <label class="ds-form-check">
        <input type="checkbox" name="ds-privacidad" />
        <span class="body-s" style="color: var(--color-gray-600)">He leído y acepto la <a href="/privacidad" class="ds-form-link">política de privacidad</a>.</span>
      </label>
    </div>
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       MODAL
  ========================================================= -->
  <Section id="modal" overline="Componentes" heading="Modal" bg="white">
    <div class="ds-row">
      <Button variant="primary" data-modal-open="ds-modal">Abrir modal</Button>
    </div>
    <Modal
      id="ds-modal"
      overline="Candidatura Enviada"
      title="Gracias por contar con nosotros"
      description="Estamos revisando tu candidatura y te contactaremos en cuanto tengamos novedades."
    />
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       BADGES
  ========================================================= -->
  <Section id="badges" overline="Componentes" heading="Badges" bg="off-white">
    <div class="ds-row ds-row--wrap">
      <Badge variant="default">Default</Badge>
      <Badge variant="accent">Accent</Badge>
      <Badge variant="success">Activo</Badge>
      <Badge variant="warning">En revisión</Badge>
      <Badge variant="error">Crítico</Badge>
      <Badge variant="info">Info</Badge>
      <Badge variant="outline">Outline</Badge>
    </div>

    <div class="ds-section-label mt-8">Uso en servicio</div>
    <div class="ds-row ds-row--wrap">
      <Badge variant="accent">CTO as a Service</Badge>
      <Badge variant="default">Soporte Avanzado</Badge>
      <Badge variant="success">SLA 99.99%</Badge>
      <Badge variant="warning">Pendiente</Badge>
    </div>
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       CARDS
  ========================================================= -->
  <Section id="cards" overline="Componentes" heading="Cards" bg="white">
    <div class="grid-3">
      <Card variant="default">
        <p class="overline">Soporte Tecnológico</p>
        <h3 style="margin-top: var(--space-3);">Continuidad garantizada</h3>
        <p class="body-s mt-4" style="color: var(--color-gray-600);">
          Operación estable y sin interrupciones. Un único responsable para toda tu tecnología.
        </p>
      </Card>

      <Card variant="ghost">
        <p class="overline">Proyectos</p>
        <h3 style="margin-top: var(--space-3);">Evolución tecnológica</h3>
        <p class="body-s mt-4" style="color: var(--color-gray-600);">
          Cloud, DevOps, desarrollo a medida. Ejecutado con contexto estratégico real.
        </p>
      </Card>

      <Card variant="navy">
        <p class="overline">CTO as a Service</p>
        <h3 style="margin-top: var(--space-3);">Liderazgo tecnológico</h3>
        <p class="body-s mt-4" style="color: var(--color-gray-400);">
          Visión a largo plazo, criterio técnico alineado con el negocio.
        </p>
      </Card>
    </div>

    <div class="ds-section-label mt-12">Card accent (callout)</div>
    <Card accent>
      <strong>Principio clave:</strong> BlueVex no compite en precio. Compite en responsabilidad, criterio y excelencia operativa.
    </Card>

    <div class="ds-section-label mt-8">Card como enlace</div>
    <div class="grid-3">
      <Card variant="default" href="/servicios/soporte">
        <p class="overline">Soporte Básico</p>
        <h4 style="margin-top: var(--space-2);">&lt; 10 empleados</h4>
        <p class="body-s mt-4" style="color: var(--color-gray-600);">Resolución crítica &lt; 6h hábiles →</p>
      </Card>
    </div>

    <div class="ds-section-label mt-12">Service Feature Card</div>
    <ServiceFeatureCard
      href="/servicios/soporte"
      title="Soporte Tecnológico"
      description="Operación continua, SLAs medibles y respuesta directa ante incidentes críticos."
      tone="cyan"
    >
      <div style="height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); color: var(--color-gray-600);">
        Demo visual
      </div>
    </ServiceFeatureCard>
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       TIMELINE
  ========================================================= -->
  <Section id="timeline" overline="Componentes" heading="Timeline" bg="white">
    <Timeline
      steps={[
        {
          title: 'Diagnóstico gratuito',
          description:
            'Una sesión. Sin PowerPoints de venta. Escuchamos, analizamos y te decimos la verdad sobre lo que está funcionando y lo que no en tu empresa.',
        },
        {
          title: 'Propuesta a medida',
          description:
            'Una propuesta con alcance cerrado, precio fijo y plazos reales. Puedes contratar un servicio o varios. Sin letra pequeña. Sin costes ocultos.',
        },
        {
          title: 'Empezamos en 48 horas',
          description:
            'Desde el primer día sabes qué pasa, quién te atiende, cómo abrir una incidencia y qué esperar de nosotros. Sin curva de aprendizaje. Sin sorpresas.',
        },
        {
          title: 'Relación continua',
          description:
            'Cada 90 días revisamos contigo si lo que tienes sigue siendo lo que necesitas. Proponemos cambios antes de que tú los pidas.',
        },
      ]}
    />
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       ICONS
  ========================================================= -->
  <Section id="icons" overline="Iconografía" heading="Phosphor Icons" bg="off-white" subheading="Variante Regular (24px) para UI estándar. Variante Light (40–64px) para elementos visuales destacados.">
    <div class="ds-icons">
      {[
        { name: 'headset',        label: 'Soporte técnico' },
        { name: 'monitor',        label: 'Monitorización' },
        { name: 'shield-check',   label: 'Continuidad' },
        { name: 'cloud-arrow-up', label: 'Cloud / Infra' },
        { name: 'code',           label: 'Ingeniería' },
        { name: 'tree-structure', label: 'Arquitectura' },
        { name: 'compass',        label: 'CTO as a Service' },
        { name: 'path',           label: 'Estrategia' },
        { name: 'arrow-right',    label: 'Arrow right' },
        { name: 'envelope-simple',label: 'Email' },
        { name: 'phone',          label: 'Teléfono' },
        { name: 'map-pin',        label: 'Ubicación' },
      ].map(icon => (
        <div class="ds-icon-item">
          <Icon name={icon.name} size={24} color="var(--color-navy)" />
          <span class="caption">{icon.label}</span>
        </div>
      ))}
    </div>

    <div class="ds-section-label mt-12">Colores autorizados</div>
    <div class="ds-row">
      <Icon name="shield-check" size={24} color="var(--color-gray-800)" />
      <Icon name="shield-check" size={24} color="var(--color-navy)" />
      <Icon name="shield-check" size={24} color="var(--color-cyan)" />
      <Icon name="shield-check" size={24} color="var(--color-gray-400)" />
      <span style="background:var(--color-navy); padding: var(--space-2); border-radius: var(--radius-md); display:inline-flex;">
        <Icon name="shield-check" size={24} color="var(--color-white)" />
      </span>
    </div>
  </Section>

  <Divider variant="default" spacing="sm" />

  <!-- ========================================================
       LOGO
  ========================================================= -->
  <Section id="logo" overline="Marca" heading="Logotipo" bg="white">
    <div class="ds-logo-grid">
      <div class="ds-logo-item ds-logo-item--light">
        <Logo variant="horizontal" theme="light" size="lg" />
        <span class="caption">Horizontal · Light · Fondo blanco</span>
      </div>
      <div class="ds-logo-item ds-logo-item--dark">
        <Logo variant="horizontal" theme="dark" size="lg" />
        <span class="caption" style="color: var(--color-gray-400);">Horizontal · Dark · Fondo navy</span>
      </div>
      <div class="ds-logo-item ds-logo-item--light">
        <Logo variant="mark-only" theme="light" size="lg" />
        <span class="caption">Isotipo · Light</span>
      </div>
      <div class="ds-logo-item ds-logo-item--dark">
        <Logo variant="mark-only" theme="dark" size="lg" />
        <span class="caption" style="color: var(--color-gray-400);">Isotipo · Dark</span>
      </div>
    </div>
  </Section>

  <Divider variant="accent" spacing="lg" />

  <!-- ========================================================
       HEADER
  ========================================================= -->
  <Section id="header" overline="Componentes" heading="Header" bg="white">
    <div style="margin-bottom: var(--space-8);">
      <p class="body-l" style="color: var(--color-gray-600); margin-bottom: var(--space-4);">
        Navegación principal sticky con logo, enlaces de navegación y CTA primario.
        Responsivo: desktop con menú expandido, mobile con hamburger menu.
      </p>
    </div>

    <div class="ds-section-label">Características</div>
    <ul style="margin-bottom: var(--space-8); padding-left: var(--space-6);">
      <li style="margin-bottom: var(--space-2); color: var(--color-gray-800);">
        <strong>Sticky:</strong> se mantiene visible al hacer scroll
      </li>
      <li style="margin-bottom: var(--space-2); color: var(--color-gray-800);">
        <strong>Glassmorphism:</strong> fondo blanco con blur y bordes suaves
      </li>
      <li style="margin-bottom: var(--space-2); color: var(--color-gray-800);">
        <strong>Links activos:</strong> indicador visual de página actual
      </li>
      <li style="margin-bottom: var(--space-2); color: var(--color-gray-800);">
        <strong>Responsive:</strong> menú hamburger en móvil (&lt; 768px)
      </li>
      <li style="color: var(--color-gray-800);">
        <strong>Shadow on scroll:</strong> sombra sutil al hacer scroll
      </li>
    </ul>

    <div class="ds-section-label mt-8">Estructura</div>
    <div style="background: var(--color-off-white); border-radius: var(--radius-lg); padding: var(--space-6); margin-bottom: var(--space-8);">
      <p style="font-family: var(--font-mono); font-size: var(--text-caption); color: var(--color-gray-600); margin-bottom: var(--space-2);">
        &lt;header&gt;
      </p>
      <ul style="padding-left: var(--space-6); font-family: var(--font-mono); font-size: var(--text-caption); color: var(--color-gray-800);">
        <li>Logo (horizontal, light)</li>
        <li>Navigation (Servicios, Nosotros, Talento)</li>
        <li>Email CTA (Hablemos)</li>
        <li>Menu toggle (mobile only)</li>
      </ul>
      <p style="font-family: var(--font-mono); font-size: var(--text-caption); color: var(--color-gray-600); margin-top: var(--space-2);">
        &lt;/header&gt;
      </p>
    </div>

    <div class="ds-section-label mt-8">Mobile Menu</div>
    <p class="body-s" style="color: var(--color-gray-600); margin-bottom: var(--space-4);">
      En pantallas menores a 768px, el menú de navegación se reemplaza por un menú hamburger que despliega un drawer vertical con todos los enlaces y el botón CTA.
    </p>
  </Section>

</BaseLayout>

<style>
  /* ---- Page hero ---- */
  .ds-hero {
    background-color: var(--color-off-white);
    padding-block: var(--space-16);
    border-bottom: var(--border-thin);
  }

  /* ---- Section labels ---- */
  .ds-section-label {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--color-gray-600);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-4);
  }

  /* ---- Color swatches ---- */
  .ds-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .swatch {
    width: 120px;
    height: 80px;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-1);
  }

  .swatch__label {
    font-size: var(--text-label-s);
    font-weight: var(--weight-medium);
    color: white;
  }

  .swatch__hex {
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(255,255,255,0.7);
  }

  .swatch--light .swatch__label,
  .swatch--light .swatch__hex {
    color: var(--color-navy);
  }
  .swatch--light .swatch__hex { color: var(--color-gray-600); }

  /* ---- Type rows ---- */
  .ds-type-row {
    padding-block: var(--space-6);
    border-bottom: var(--border-thin);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .ds-type-row:last-child { border-bottom: none; }

  .ds-type-label {
    color: var(--color-cyan);
  }

  /* ---- Component rows ---- */
  .ds-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .ds-row--wrap { flex-wrap: wrap; }

  /* ---- Form styles ---- */
  .ds-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 720px;
  }

  .ds-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .ds-form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .ds-form-label {
    font-size: var(--text-label);
    font-weight: var(--weight-medium);
    color: var(--color-navy);
  }

  .ds-form-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-gray-400);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-body-s);
    color: var(--color-gray-800);
    background: var(--color-white);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
    -webkit-appearance: none;
  }

  .ds-form-input:hover { border-color: var(--color-gray-500); }
  .ds-form-input:focus { border-color: var(--color-cyan); box-shadow: 0 0 0 3px rgba(47, 164, 217, 0.12); }
