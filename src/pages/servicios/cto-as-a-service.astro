---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import EmailCta from '../../components/ui/EmailCta.astro';
import Card from '../../components/ui/Card.astro';
import Section from '../../components/layout/Section.astro';
import Badge from '../../components/ui/Badge.astro';
import Icon from '../../components/shared/Icon.astro';

const packages = [
  {
    name: 'CTO Básico',
    target: 'Microempresas',
    hours: '6h / mes',
    meeting: 'Reunión mensual',
    includes: [
      'Ayudar a elegir bien desde el principio',
      'Decidir qué merece la pena hacer y qué no',
      'Revisar propuestas de proveedores y desarrolladores',
      'Dar una hoja de ruta clara para los próximos meses',
      'Resolver dudas técnicas en lenguaje de negocio',
    ],
  },
  {
    name: 'CTO Estándar',
    target: 'Pequeñas empresas',
    hours: '10h / mes',
    meeting: 'Reunión mensual',
    highlighted: true,
    includes: [
      'Poner orden en todo lo que ya tienes',
      'Definir prioridades claras y ejecutables',
      'Alinear la tecnología con lo que el negocio necesita',
      'Coordinar proveedores y equipo técnico',
      'Asesorar dónde invertir tecnológicamente y dónde no',
    ],
  },
  {
    name: 'CTO Avanzado',
    target: 'Medianas empresas',
    hours: '20h / mes',
    meeting: 'Reunión semanal',
    includes: [
      'Definir hacia dónde debe ir tu tecnología',
      'Revisar si lo que tienes escala y es sostenible',
      'Alinear IT con dirección y negocio',
      'Ayudar a los responsables técnicos a tomar mejores decisiones',
      'Reducir riesgos y dependencia de personas clave',
    ],
  },
  {
    name: 'CTO Premium',
    target: 'Grandes empresas',
    hours: '35h / mes',
    meeting: 'Reunión semanal + comités',
    includes: [
      'Aportar visión externa y objetiva',
      'Ayudar a tomar decisiones críticas con menos riesgo',
      'Participar en comités tecnológicos',
      'Revisar grandes decisiones antes de ejecutarlas',
      'Alinear tecnología, negocio y dirección',
    ],
  },
];
---

<BaseLayout
  title="CTO as a Service — BlueVex"
  description="Liderazgo tecnológico estratégico sin CTO a tiempo completo. Arquitectura, gobernanza IT, criterio técnico y decisiones alineadas con tu negocio."
  currentPath="/servicios/cto-as-a-service"
>
  <section class="page-hero bg-white">
    <div class="container">
      <a href="/servicios" class="breadcrumb caption">← Servicios</a>
      <p class="overline mt-4">CTO as a Service</p>
      <h1 class="display page-hero__title">Liderazgo tecnológico<br />cuando más lo necesitas.</h1>
      <p class="body-l page-hero__sub">La tecnología de tu empresa necesita dirección, no solo ejecución. Un CTO as a Service te da visión estratégica, criterio técnico y alineación con el negocio, sin el coste de una contratación a tiempo completo.</p>
    </div>
  </section>

  <Section bg="off-white" size="md">
    <div class="grid-3">
      {[
        { icon: 'compass',      title: 'Visión a largo plazo',    desc: 'Decisiones técnicas evaluadas por su impacto hoy y su coste en 18 meses. Evitamos que lo urgente eclipse lo importante.' },
        { icon: 'tree-structure', title: 'Arquitectura sostenible', desc: 'Revisamos si lo que tienes escala. Identificamos dependencias críticas y reducimos la deuda técnica acumulada.' },
        { icon: 'shield-check', title: 'Criterio sin conflicto',   desc: 'No tenemos interés en vender más horas. Nuestra recomendación siempre es la que más le conviene al negocio del cliente.' },
      ].map(i => (
        <Card variant="default">
          <Icon name={i.icon} size={24} color="var(--color-cyan)" />
          <h4 class="mt-4">{i.title}</h4>
          <p class="body-s mt-2" style="color:var(--color-gray-600)">{i.desc}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section bg="white" overline="Modalidades" heading="Elige tu nivel de acompañamiento" size="lg">
    <div class="packages-grid">
      {packages.map(p => (
        <div class={`pkg-card ${p.highlighted ? 'pkg-card--highlight' : ''}`}>
          {p.highlighted && <div class="pkg-badge">Más contratado</div>}
          <h3 class="pkg-name">{p.name}</h3>
          <p class="pkg-target caption">{p.target}</p>
          <div class="pkg-hours">
            <span class="label">{p.hours}</span>
            <span class="caption" style="color:var(--color-gray-600)"> · {p.meeting}</span>
          </div>
          <ul class="pkg-list">
            {p.includes.map(item => (
              <li class="pkg-item">
                <Icon name="check" size={16} color="var(--color-success)" />
                <span class="body-s">{item}</span>
              </li>
            ))}
          </ul>
          <Button href="/contacto" variant={p.highlighted ? 'primary' : 'secondary'} fullWidth>
            Solicitar propuesta
          </Button>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="navy" size="md" centered>
    <h2 style="color:var(--color-white)">¿No tienes CTO pero necesitas uno?</h2>
    <p class="body-l mt-4" style="color:var(--color-gray-400); max-width:480px; margin-inline:auto;">Cuéntanos dónde estás tecnológicamente. Te decimos qué nivel de acompañamiento tiene sentido para tu empresa ahora mismo.</p>
    <div class="mt-8"><EmailCta size="lg" variant="dark" /></div>
  </Section>
</BaseLayout>

<style>
  .page-hero { padding-block:var(--space-16); }
  .page-hero__title { color:var(--color-navy); margin-top:var(--space-4); }
  .page-hero__sub   { color:var(--color-gray-600); max-width:580px; margin-top:var(--space-5); }
  .breadcrumb { color:var(--color-gray-600); text-decoration:none; }
  .breadcrumb:hover { color:var(--color-navy); }

  .packages-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-4); align-items:stretch; }

  .pkg-card {
    border:var(--border-thin);
    border-radius:var(--radius-xl);
    padding:var(--space-6);
    background:var(--color-white);
    position:relative;
    display:flex;
    flex-direction:column;
    gap:var(--space-4);
    height: 100%;
  }
  .pkg-card--highlight { border-color:var(--color-navy); box-shadow:var(--shadow-md); }
  .pkg-badge { position:absolute; top:-12px; left:50%; transform:translateX(-50%); background:var(--color-navy); color:var(--color-white); font-size:var(--text-label-s); font-weight:var(--weight-medium); padding:var(--space-1) var(--space-3); border-radius:var(--radius-full); white-space:nowrap; }
  .pkg-name   { font-size:var(--text-h3); color:var(--color-navy); }
  .pkg-target { color:var(--color-gray-600); }
  .pkg-hours  { padding-block:var(--space-3); border-block:var(--border-thin); }
  .pkg-list   { display:flex; flex-direction:column; gap:var(--space-2); flex:1; }
  .pkg-item   { display:flex; align-items:flex-start; gap:var(--space-2); }
  .pkg-item .body-s { color:var(--color-gray-600); }

  @media (max-width:1024px) { .packages-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:640px)  { .packages-grid { grid-template-columns:1fr; } }
</style>
