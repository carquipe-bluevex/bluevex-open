---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import EmailCta from '../../components/ui/EmailCta.astro';
import Section from '../../components/layout/Section.astro';
import Icon from '../../components/shared/Icon.astro';
---

<BaseLayout
  title="Licenciamiento — BlueVex"
  description="Auditoría, selección y gestión de licencias de software de terceros sin conflictos de interés. Optimiza costos de TI y negocia mejores términos."
  currentPath="/servicios/licenciamiento"
>
  <section class="page-hero bg-white">
    <div class="container">
      <a href="/servicios" class="breadcrumb caption">← Servicios</a>
      <p class="overline mt-4">Licenciamiento</p>
      <h1 class="display page-hero__title">Gestión inteligente<br />de tus licencias.</h1>
      <p class="body-l page-hero__sub">Auditoría, selección y optimización de licencias de software. Reducimos costes, evitamos excesos y negociamos mejores términos sin conflictos de interés.</p>
    </div>
  </section>

  <Section bg="white" size="lg" overline="Lo que gestionamos" heading="Plataformas de terceros">
    <ul class="lic-list">
      {['Microsoft 365 y Azure', 'Google Workspace', 'Herramientas de productividad y colaboración', 'Plataformas de seguridad y backup', 'Software de gestión empresarial', 'Soluciones de análisis y BI'].map(item => (
        <li class="lic-list__item"><Icon name="check" size={16} color="var(--color-success)" /><span class="body-s">{item}</span></li>
      ))}
    </ul>
  </Section>

  <Section bg="off-white" overline="Cómo gestionamos las licencias" heading="Principios que no negociamos" size="md">
    <div class="grid-2" style="gap:var(--space-4)">
      {[
        { title: 'Criterio técnico sobre margen comercial', desc: 'La elección de una plataforma es independiente del incentivo comercial asociado. Siempre.' },
        { title: 'Separación explícita licencia/servicio', desc: 'El derecho de uso (licencia) y la responsabilidad operativa (servicio) se definen en contratos separados.' },
        { title: 'Transparencia total con el cliente', desc: 'El cliente sabe quién es el titular de la licencia, qué cubre el fabricante y qué cubre BlueVex.' },
        { title: 'Gestión del ciclo de vida completo', desc: 'Alta, configuración, cambios de volumen, renovaciones y revisión periódica de uso y adecuación.' },
      ].map(p => (
        <div class="principle-item">
          <Icon name="check" size={20} color="var(--color-cyan)" />
          <div>
            <h4>{p.title}</h4>
            <p class="body-s mt-1" style="color:var(--color-gray-600)">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="navy" size="md" centered>
    <div class="prefooter-cta">
      <h2 class="prefooter-cta__title">¿Buscas la plataforma adecuada para tu empresa?</h2>
      <p class="body-l prefooter-cta__copy">Analizamos tu situación actual y te recomendamos las herramientas que realmente necesitas, sin inflar la factura.</p>
      <div class="prefooter-cta__actions"><EmailCta size="lg" variant="dark" buttonLabel="Solicitar asesoramiento" /></div>
    </div>
  </Section>
</BaseLayout>

<style>
  .page-hero { padding-block:var(--space-16); }
  .page-hero__title { color:var(--color-navy); margin-top:var(--space-4); }
  .page-hero__sub   { color:var(--color-gray-600); max-width:580px; margin-top:var(--space-5); }
  .breadcrumb { color:var(--color-gray-600); text-decoration:none; }
  .breadcrumb:hover { color:var(--color-navy); }
  .lic-icon { width:64px; height:64px; background:var(--color-off-white); border-radius:var(--radius-lg); display:flex; align-items:center; justify-content:center; }
  .lic-list { display:flex; flex-direction:column; gap:var(--space-3); }
  .lic-list__item { display:flex; align-items:flex-start; gap:var(--space-2); }
  .lic-list__item .body-s { color:var(--color-gray-600); }
  .principle-item { display:flex; align-items:flex-start; gap:var(--space-4); padding:var(--space-6); background:var(--color-white); border-radius:var(--radius-lg); border:var(--border-thin); }

  .prefooter-cta {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .prefooter-cta__title {
    color: var(--color-white);
  }

  .prefooter-cta__copy {
    color: var(--color-gray-400);
    margin-top: var(--space-4);
    max-width: 520px;
    margin-inline: auto;
  }

  .prefooter-cta__actions {
    margin-top: var(--space-8);
    display: flex;
    justify-content: center;
  }
</style>
