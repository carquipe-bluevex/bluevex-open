---
/**
 * Icon — BlueVex Phosphor Icons wrapper
 * Official icon library: Phosphor Icons (phosphoricons.com)
 * Authorized variants: regular | light
 * Authorized sizes: 16 | 20 | 24 | 40 | 48 | 64
 *
 * Usage: <Icon name="headset" size={24} />
 *
 * NOTE: This component renders inline SVG placeholder until
 * @phosphor-icons/astro is installed. Once installed,
 * swap the SVG block for: import { [Name] } from '@phosphor-icons/astro'
 */

interface Props {
  name: string;
  size?: 16 | 20 | 24 | 40 | 48 | 64;
  weight?: 'regular' | 'light';
  color?: string;
  class?: string;
  'aria-hidden'?: boolean;
  'aria-label'?: string;
}

const {
  name,
  size = 24,
  weight = 'regular',
  color = 'currentColor',
  class: className = '',
  'aria-hidden': ariaHidden = true,
  'aria-label': ariaLabel,
} = Astro.props;

const strokeWidth = weight === 'light' ? 1.25 : 1.75;

