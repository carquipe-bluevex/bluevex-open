---
/**
 * Picture Component — Responsive image with WebP/AVIF fallback
 * Usage:
 *   <Picture src="/assets/image.png" alt="Description" loading="lazy" />
 */

interface Props {
  src: string;
  alt: string;
  loading?: 'lazy' | 'eager';
  class?: string;
  title?: string;
  width?: number | string;
  height?: number | string;
  decoding?: 'sync' | 'async' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
}

const {
  src,
  alt,
  loading = 'lazy',
  class: className = '',
  title,
  width,
  height,
  decoding,
  fetchpriority,
  sizes,
} = Astro.props;

// Extract path without extension
const basePath = src.replace(/\.[^/.]+$/, '');
const avifSrc = `${basePath}.avif`;
const webpSrc = `${basePath}.webp`;
---

<picture>
  <source srcset={avifSrc} type="image/avif" />
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={src}
    alt={alt}
    loading={loading}
    class={className}
    title={title}
    width={width}
    height={height}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
  />
</picture>

<style>
  img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
