---
/**
 * EmailCta — Email input + CTA button
 * Sends the email to the contact page using a GET query param.
 */

interface Props {
  action?: string;
  placeholder?: string;
  buttonLabel?: string;
  size?: 'sm' | 'md' | 'lg';
  inputName?: string;
  value?: string;
  fullWidth?: boolean;
  variant?: 'light' | 'dark';
  class?: string;
}

const {
  action = '/contacto',
  placeholder = 'Tu email',
  buttonLabel = 'Hablemos',
  size = 'md',
  inputName = 'email',
  value = '',
  fullWidth = false,
  variant = 'light',
  class: className = '',
} = Astro.props;

const classes = [
  'email-cta',
  `email-cta--${size}`,
  `email-cta--${variant}`,
  fullWidth && 'email-cta--full',
  className,
].filter(Boolean).join(' ');
---

<form class={classes} action={action} method="get">
  <input
    class="email-cta__input"
    type="email"
    name={inputName}
    placeholder={placeholder}
    value={value}
    autocomplete="email"
    aria-label={placeholder}
    required
  />
  <button class="email-cta__button" type="submit">
    {buttonLabel}
  </button>
</form>

<style>
  .email-cta {
    display: inline-flex;
    align-items: stretch;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  /* LIGHT VARIANT (default) */
  .email-cta--light {
    border: 1px solid var(--color-gray-100);
    background: var(--color-white);
  }

  .email-cta--light:focus-within {
    border-color: var(--color-navy);
    box-shadow: 0 0 0 3px rgba(22, 38, 76, 0.12);
  }

  .email-cta--light .email-cta__input {
    color: var(--color-navy);
  }

  .email-cta--light .email-cta__input::placeholder {
    color: var(--color-gray-400);
  }

  .email-cta--light .email-cta__button {
    background-color: var(--color-navy);
    color: var(--color-white);
  }

  .email-cta--light .email-cta__button:hover {
    background-color: var(--color-steel-blue);
  }

  .email-cta--light .email-cta__button:active {
    background-color: #0f1b38;
  }

  /* DARK VARIANT (for navy backgrounds) */
  .email-cta--dark {
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
  }

  .email-cta--dark:focus-within {
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 0 0 3px rgba(47, 164, 217, 0.25);
  }

  .email-cta--dark .email-cta__input {
    color: var(--color-white);
  }

  .email-cta--dark .email-cta__input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .email-cta--dark .email-cta__button {
    background: linear-gradient(135deg, rgba(47, 164, 217, 0.9) 0%, rgba(47, 164, 217, 0.8) 100%);
    color: var(--color-white);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .email-cta--dark .email-cta__button:hover {
    background: linear-gradient(135deg, var(--color-cyan) 0%, rgba(47, 164, 217, 0.9) 100%);
  }

  .email-cta--dark .email-cta__button:active {
    opacity: 0.95;
  }

  .email-cta--full {
    width: 100%;
  }

  .email-cta__input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    min-width: 240px;
  }

  .email-cta__input:focus {
    outline: none;
  }

  .email-cta__button {
    border: none;
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    white-space: nowrap;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  /* SIZE VARIANTS */
  .email-cta.email-cta--sm .email-cta__input {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-label-s);
  }

  .email-cta.email-cta--sm .email-cta__button {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-label-s);
  }

  .email-cta.email-cta--md .email-cta__input {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-label);
  }

  .email-cta.email-cta--md .email-cta__button {
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-label);
  }

  .email-cta.email-cta--lg .email-cta__input {
    padding: var(--space-4) var(--space-5);
    font-size: var(--text-body);
  }

  .email-cta.email-cta--lg .email-cta__button {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-body);
  }

  .email-cta--compact .email-cta__input {
    width: 200px;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .email-cta {
      width: 100%;
      flex-direction: column;
    }

    .email-cta__input {
      min-width: auto;
      width: 100%;
    }

    .email-cta.email-cta--sm .email-cta__input {
      padding: var(--space-3) var(--space-3);
      font-size: 0.875rem;
    }

    .email-cta.email-cta--sm .email-cta__button {
      padding: var(--space-3) var(--space-3);
      font-size: 0.875rem;
    }

    .email-cta.email-cta--md .email-cta__input {
      padding: var(--space-3) var(--space-3);
      font-size: 0.95rem;
    }

    .email-cta.email-cta--md .email-cta__button {
      padding: var(--space-3) var(--space-3);
      font-size: 0.95rem;
      width: 100%;
    }

    .email-cta.email-cta--lg .email-cta__input {
      padding: var(--space-4) var(--space-3);
      font-size: 1rem;
    }

    .email-cta.email-cta--lg .email-cta__button {
      padding: var(--space-4) var(--space-3);
      font-size: 1rem;
      width: 100%;
    }
  }
</style>
