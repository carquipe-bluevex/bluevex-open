---
interface Props {
  type?: 'contact' | 'talent';
  isOpen?: boolean;
}

const { type = 'contact', isOpen = false } = Astro.props;

const messages = {
  contact: {
    title: 'Mensaje recibido',
    subtitle: 'Nos pondremos en contacto en breve. Gracias por tu confianza.',
  },
  talent: {
    title: '¡Bienvenido al equipo!',
    subtitle: 'Hemos recibido tu candidatura. Pronto te contactaremos para hablar de tu proyecto con nosotros.',
  },
};

const content = messages[type] || messages.contact;
---

<div class="success-modal" role="dialog" aria-modal="true" aria-hidden={!isOpen}>
  <div class="success-modal__backdrop"></div>

  <div class="success-modal__container">
    <!-- Success Icon with Glow -->
    <div class="success-icon-wrapper">
      <div class="success-icon-glow"></div>
      <svg
        class="success-icon"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>

    <!-- Content -->
    <div class="success-modal__content">
      <h2 class="success-modal__title">{content.title}</h2>
      <p class="success-modal__subtitle">{content.subtitle}</p>
    </div>

    <!-- Action Button -->
    <div class="success-modal__actions">
      <button
        class="success-modal__button"
        onclick="this.closest('.success-modal').setAttribute('data-closed', 'true')"
      >
        Continuar
      </button>
    </div>

    <!-- Decoration Elements -->
    <div class="success-decoration success-decoration--1"></div>
    <div class="success-decoration success-decoration--2"></div>
  </div>
</div>

<style>
  /* ===== MODAL STRUCTURE ===== */
  .success-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease-out;
  }

  .success-modal[data-closed='true'] {
    opacity: 0;
    pointer-events: none;
  }

  .success-modal:not([aria-hidden='true']) {
    opacity: 1;
    pointer-events: auto;
  }

  /* Backdrop */
  .success-modal__backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(22, 46, 76, 0.4);
    backdrop-filter: blur(4px);
    animation: backdropFadeIn 0.4s ease-out;
  }

  /* Container */
  .success-modal__container {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #f5f8fc 100%);
    border-radius: var(--radius-2xl, 24px);
    padding: var(--space-8, 48px) var(--space-6, 32px);
    max-width: 420px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(22, 46, 76, 0.15),
      0 0 1px rgba(47, 164, 217, 0.2);
    border: 1px solid rgba(47, 164, 217, 0.1);
    text-align: center;
    animation: containerSlideUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ===== SUCCESS ICON ===== */
  .success-icon-wrapper {
    position: relative;
    width: 72px;
    height: 72px;
    margin: 0 auto var(--space-6, 32px);
  }

  /* Glow effect */
  .success-icon-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(47, 164, 217, 0.3) 0%, transparent 70%);
    border-radius: 50%;
    animation: glowPulse 2s ease-in-out infinite;
  }

  /* Icon circle background */
  .success-icon-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #2fa4d9 0%, #1e7ca5 100%);
    border-radius: 50%;
    animation: iconScaleIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 1;
  }

  .success-icon {
    position: relative;
    width: 100%;
    height: 100%;
    color: white;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: checkmarkDraw 0.8s ease-out 0.2s forwards;
    z-index: 2;
  }

  /* ===== CONTENT ===== */
  .success-modal__content {
    margin-bottom: var(--space-6, 32px);
  }

  .success-modal__title {
    font-family: 'Poppins', 'Segoe UI', sans-serif;
    font-size: clamp(1.5rem, 5vw, 1.75rem);
    font-weight: 700;
    color: var(--color-navy, #162e4c);
    line-height: 1.3;
    margin-bottom: var(--space-2, 12px);
    letter-spacing: -0.5px;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }

  .success-modal__subtitle {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray-600, #6b7280);
    margin: 0;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }

  /* ===== BUTTON ===== */
  .success-modal__actions {
    animation: fadeInUp 0.6s ease-out 0.3s both;
  }

  .success-modal__button {
    display: inline-block;
    padding: var(--space-3, 16px) var(--space-6, 32px);
    background: linear-gradient(135deg, #162e4c 0%, #1a3857 100%);
    color: white;
    border: none;
    border-radius: var(--radius-lg, 12px);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px rgba(22, 46, 76, 0.25);
  }

  .success-modal__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(22, 46, 76, 0.35);
    background: linear-gradient(135deg, #1a3857 0%, #16324f 100%);
  }

  .success-modal__button:active {
    transform: translateY(0);
  }

  /* ===== DECORATIONS ===== */
  .success-decoration {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .success-decoration--1 {
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(47, 164, 217, 0.08) 0%, transparent 70%);
    top: -40px;
    right: -40px;
    animation: float 6s ease-in-out infinite;
  }

  .success-decoration--2 {
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(47, 164, 217, 0.05) 0%, transparent 70%);
    bottom: -30px;
    left: -30px;
    animation: float 8s ease-in-out infinite reverse;
  }

  /* ===== ANIMATIONS ===== */
  @keyframes backdropFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes containerSlideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes iconScaleIn {
    0% {
      transform: scale(0.5);
      opacity: 0;
    }
    70% {
      transform: scale(1.1);
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  @keyframes checkmarkDraw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes glowPulse {
    0%,
    100% {
      opacity: 0.5;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1.15);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    .success-modal__container {
      padding: var(--space-6, 32px) var(--space-4, 20px);
      margin: 0 var(--space-3, 16px);
    }

    .success-modal__title {
      font-size: 1.5rem;
    }

    .success-modal__subtitle {
      font-size: 0.9rem;
    }

    .success-modal__button {
      padding: var(--space-2, 12px) var(--space-5, 24px);
      font-size: 0.9rem;
      width: 100%;
    }

    .success-icon-wrapper {
      width: 64px;
      height: 64px;
      margin-bottom: var(--space-5, 24px);
    }
  }
</style>

<script>
  // Expose modal controls globally
  (window as any).openSuccessModal = function (type: 'contact' | 'talent' = 'contact') {
    const modal = document.querySelector(
      `[data-success-modal-type="${type}"]`
    ) as HTMLElement;
    if (modal) {
      modal.setAttribute('aria-hidden', 'false');
      modal.removeAttribute('data-closed');
    }
  };

  (window as any).closeSuccessModal = function (type: 'contact' | 'talent' = 'contact') {
    const modal = document.querySelector(
      `[data-success-modal-type="${type}"]`
    ) as HTMLElement;
    if (modal) {
      modal.setAttribute('aria-hidden', 'true');
    }
  };

  // Auto-close on ESC key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const openModals = document.querySelectorAll('[data-success-modal-type]:not([aria-hidden="true"])');
      openModals.forEach((modal) => {
        modal.setAttribute('aria-hidden', 'true');
      });
    }
  });

  // Close on backdrop click
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('success-modal__backdrop')) {
      const modal = target.closest('.success-modal') as HTMLElement;
      if (modal) {
        modal.setAttribute('aria-hidden', 'true');
      }
    }
  });
</script>
