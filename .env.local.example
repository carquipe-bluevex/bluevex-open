# Local development example
# Copy to .env.local and adjust values if needed.

RESEND_API_KEY=your_resend_api_key
RESEND_FROM=BlueVex <no-reply@bluevex.tech>

# Cloudflare Turnstile test keys (always-pass pair)
# Docs: https://developers.cloudflare.com/turnstile/reference/testing/
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Allowed domains returned by Turnstile verification in production.
# For local dev this is bypassed, so it can stay empty.
TURNSTILE_ALLOWED_HOSTNAMES=

ALLOWED_FORM_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
